#!/usr/bin/env bash
# digiin — unified CLI: local dev sessions + EC2 demo server ops
# Run `digiin help` for the full command list.

MAIN_DIR="$HOME/digiin/project"
WORKTREE_BASE="$HOME/digiin"

# EC2 demo server (on-demand — see digiin-ec2 / digiin-status skills).
# Instance-specific identifiers live outside this (public) repo — create
# ~/.config/digiin/env (chmod 600) with:  INSTANCE_ID=i-xxxx  EC2_REGION=us-east-2
DIGIIN_ENV="${DIGIIN_ENV:-$HOME/.config/digiin/env}"
# shellcheck source=/dev/null
[[ -f "$DIGIIN_ENV" ]] && source "$DIGIIN_ENV"
EC2_REGION="${EC2_REGION:-us-east-2}"
require_ec2() {
  [[ -n "${INSTANCE_ID:-}" ]] && return 0
  echo "digiin: INSTANCE_ID not set — add it to $DIGIIN_ENV (chmod 600)." >&2
  exit 1
}
# Connect by the current AWS-reported IP, not by the box's DNS name — the on-boot
# Cloudflare DNS update can lag/fail, so the IP is the reliable source of truth.
SSH_KEY="$HOME/.ssh/id_ed25519"
SSH_OPTS=(-o ConnectTimeout=8 -o StrictHostKeyChecking=accept-new)
GH_REPO="${GH_REPO:-digiin-software/digiin}"

# Workflows `digiin ci on|off` toggles. cd-dev is never in this list — it is
# the deploy path and must stay enabled.
#
# Refreshed 2026-07-22: five of the old entries were retired on 2026-07-20
# (cleanup-stale-ci-runs, mutation, validate-backend-tests, validate-locales,
# validate-schema, verify-docs-weekly) and `gh workflow disable` errors on a
# name that no longer exists, so the whole loop bailed partway through.
WORKFLOWS=(audit backup-board cleanup-branches secret-scan security-audit
  validate-build validate-lint validate-tests validate-types)

if [[ ! -d "$MAIN_DIR" ]]; then
  echo "Error: $MAIN_DIR does not exist"
  exit 1
fi

check_infra() {
  if ! colima status &>/dev/null; then
    echo "Infra not running. Run: digiin init"
    exit 1
  fi
  if ! docker ps --format '{{.Names}}' 2>/dev/null | grep -q "digiin-postgres"; then
    echo "Containers not running. Run: digiin init"
    exit 1
  fi
}

cmd_init() {
  if ! colima status &>/dev/null; then
    echo "Starting Colima..."
    colima start
  else
    echo "Colima already running"
  fi

  local running
  running=$(docker ps --format '{{.Names}}' 2>/dev/null)
  if ! echo "$running" | grep -q "digiin-postgres"; then
    echo "Starting containers..."
    (cd "$MAIN_DIR" && docker-compose up -d postgres redis)
  else
    echo "Containers already running"
  fi

  echo "Infra ready"
}

setup_dev_window() {
  local target="$1"
  local dir="$2"
  tmux split-window -h -t "$target" -c "$dir"
  tmux send-keys -t "${target}.1" "nvim" Enter
  tmux send-keys -t "${target}.2" "claude --dangerously-skip-permissions" Enter
  tmux resize-pane -t "${target}.2" -x "80%"
  tmux select-pane -t "${target}.1"
}

open_session() {
  local session="$1"
  local dir="$2"
  local window_name="$3"

  if tmux has-session -t "$session" 2>/dev/null; then
    if ! tmux list-windows -t "$session" -F '#W' | grep -q "^${window_name}$"; then
      tmux new-window -t "$session" -n "$window_name" -c "$dir"
      setup_dev_window "$session:$window_name" "$dir"
    fi
    tmux select-window -t "$session:$window_name"
    tmux attach-session -t "$session"
  else
    tmux new-session -d -s "$session" -n "$window_name" -c "$dir" -x "$(tput cols)" -y "$(tput lines)"
    setup_dev_window "$session:$window_name" "$dir"
    tmux attach-session -t "$session"
  fi
}

cmd_open() {
  check_infra
  local main_branch
  main_branch=$(git -C "$MAIN_DIR" branch --show-current)
  open_session "digiin" "$MAIN_DIR" "${main_branch:-main}"
}

cmd_wt() {
  local branch="$1"
  if [[ -z "$branch" ]]; then
    echo "Usage: digiin wt <branch>"
    exit 1
  fi

  check_infra

  local worktree_dir="$WORKTREE_BASE/$branch"

  if [[ ! -d "$worktree_dir" ]]; then
    if git -C "$MAIN_DIR" show-ref --verify --quiet "refs/heads/$branch" 2>/dev/null; then
      git -C "$MAIN_DIR" worktree add "$worktree_dir" "$branch"
    elif git -C "$MAIN_DIR" show-ref --verify --quiet "refs/remotes/origin/$branch" 2>/dev/null; then
      git -C "$MAIN_DIR" worktree add "$worktree_dir" "$branch"
    else
      git -C "$MAIN_DIR" worktree add -b "$branch" "$worktree_dir"
    fi

    # Copy .env files from main project
    while IFS= read -r envfile; do
      local rel="${envfile#"$MAIN_DIR"/}"
      local target="$worktree_dir/$rel"
      if [[ ! -f "$target" ]]; then
        mkdir -p "$(dirname "$target")"
        cp "$envfile" "$target"
      fi
    done < <(git -C "$MAIN_DIR" ls-files --others --ignored --exclude-standard -- '*.env' '*.env.*' | \
      grep -v '.env.example' | \
      sed "s|^|$MAIN_DIR/|")
  fi

  open_session "digiin-$branch" "$worktree_dir" "$branch"
}

cmd_ls() {
  while IFS= read -r line; do
    local path branch name session_name status
    path=$(echo "$line" | awk '{print $1}')
    branch=$(echo "$line" | grep -o '\[.*\]' | tr -d '[]')
    name=$(basename "$path")

    if [[ "$path" == "$MAIN_DIR" ]]; then
      session_name="digiin"
      name="project"
    else
      session_name="digiin-$name"
    fi

    if tmux has-session -t "$session_name" 2>/dev/null; then
      status="active"
    else
      status="-"
    fi

    printf "  %-20s %-25s %s\n" "$name" "$branch" "$status"
  done < <(git -C "$MAIN_DIR" worktree list)
}

cmd_rm() {
  local branch="$1"
  local worktree_dir="$WORKTREE_BASE/$branch"

  if [[ -z "$branch" ]]; then
    echo "Usage: digiin rm <branch>"
    echo ""
    echo "Active worktrees:"
    cmd_ls
    exit 1
  fi

  if [[ "$worktree_dir" == "$MAIN_DIR" ]]; then
    echo "Error: cannot remove main project"
    exit 1
  fi

  tmux kill-session -t "digiin-$branch" 2>/dev/null

  if git -C "$MAIN_DIR" worktree list | grep -q "$worktree_dir"; then
    git -C "$MAIN_DIR" worktree remove "$worktree_dir" --force
    echo "Removed worktree: $branch"
  else
    echo "Error: worktree '$branch' not found"
    exit 1
  fi
}

# ─── EC2 demo server (on-demand) ─────────────────────────────────────────────

ec2_state() {
  aws ec2 describe-instances --instance-ids "$INSTANCE_ID" --region "$EC2_REGION" \
    --query 'Reservations[0].Instances[0].State.Name' --output text 2>/dev/null || echo "unknown"
}

ec2_ip() {
  aws ec2 describe-instances --instance-ids "$INSTANCE_ID" --region "$EC2_REGION" \
    --query 'Reservations[0].Instances[0].PublicIpAddress' --output text 2>/dev/null || echo "none"
}

# SSH to the box by its current public IP (robust to stale DNS). Extra args -> remote command.
ec2_ssh() {
  local ip; ip=$(ec2_ip)
  if [[ -z "$ip" || "$ip" == "none" || "$ip" == "None" ]]; then
    echo "No public IP (instance not running?)." >&2
    return 1
  fi
  ssh "${SSH_OPTS[@]}" -i "$SSH_KEY" "ec2-user@$ip" "$@"
}

# Verify the on-boot Cloudflare update actually succeeded for the current IP.
# Reads the box's own update-dns log — catches a stale/expired CF token the same
# boot instead of days later (the failure mode that bit us 2026-07-18).
check_dns() {
  local ip; ip=$(ec2_ip)
  local line; line=$(ec2_ssh "sudo grep -F '$ip' /var/log/update-dns.log 2>/dev/null | tail -1" 2>/dev/null)
  if [[ "$line" == *"- true" ]]; then
    echo "DNS on-boot OK ($ip)."
  else
    echo "!! DNS on-boot did NOT confirm success for $ip (stale Cloudflare token?)."
    echo "   last entry: ${line:-<none for this IP>}"
    echo "   check: digiin ssh -> sudo tail -3 /var/log/update-dns.log"
    echo "   fix:   re-roll the Cloudflare token and update ~/update-dns.sh on the box"
  fi
}

cmd_start() {
  local s; s=$(ec2_state)
  if [[ "$s" == "running" ]]; then
    echo "Already running (IP $(ec2_ip))."
    check_dns
    return 0
  fi
  echo "Starting $INSTANCE_ID..."
  aws ec2 start-instances --instance-ids "$INSTANCE_ID" --region "$EC2_REGION" >/dev/null
  aws ec2 wait instance-running --instance-ids "$INSTANCE_ID" --region "$EC2_REGION"
  echo "running. IP: $(ec2_ip)"
  printf "Waiting for SSH"
  local i
  for i in $(seq 1 30); do
    if ec2_ssh true 2>/dev/null; then
      echo " -> OK after $((i * 5))s."
      check_dns
      echo "Ready to deploy."
      return 0
    fi
    printf "."
    sleep 5
  done
  echo ""
  echo "Note: SSH not responding yet (on-boot DNS may lag). Retry shortly."
}

cmd_stop() {
  local s; s=$(ec2_state)
  if [[ "$s" == "stopped" ]]; then echo "Already stopped."; return 0; fi
  echo "Stopping $INSTANCE_ID..."
  aws ec2 stop-instances --instance-ids "$INSTANCE_ID" --region "$EC2_REGION" >/dev/null
  aws ec2 wait instance-stopped --instance-ids "$INSTANCE_ID" --region "$EC2_REGION"
  echo "stopped. Compute off (only EBS ~\$2.40/mo remains)."
}

cmd_status() {
  local s; s=$(ec2_state)
  echo "state : $s"
  [[ "$s" == "running" ]] && echo "ip    : $(ec2_ip)"
  echo "(full dashboard: digiin-status skill)"
}

# Triggers the cd-dev.yml pipeline instead of SSH-ing into deploy.sh.
#
# deploy.sh was left behind by the monorepo restructure: build_images() still
# builds from source/backend/Dockerfile, a path that has not existed since the
# apps/ split, so `deploy.sh update` fails at the build step. Rather than fix
# and then maintain two deploy paths in parallel, this drives the one that
# works and is already wired end to end.
#
# The pipeline is also the only path that runs the `gate` job (typecheck +
# registry audits on the runner). SSH-ing straight to a rebuild skipped it.
cmd_deploy() {
  local branch="${1:-demo}"

  local s; s=$(ec2_state)
  if [[ "$s" != "running" ]]; then
    echo "Instance $s -> starting first..."
    cmd_start
  fi

  # The runner lives on the EC2 box; if it has not registered yet the run
  # queues forever with no indication why.
  echo "Waiting for the self-hosted runner to come online..."
  local i
  for i in $(seq 1 30); do
    if gh api "/repos/$GH_REPO/actions/runners" --jq \
        '[.runners[] | select(.status == "online")] | length' 2>/dev/null | grep -qv '^0$'; then
      echo "  runner online."
      break
    fi
    [[ $i -eq 30 ]] && { echo "  runner never came online after 150s. Check: ssh digiin-dev 'sudo systemctl status actions.runner.*'"; return 1; }
    sleep 5
  done

  echo "Dispatching cd-dev.yml on '$branch' (gate -> build -> migrate -> health)..."
  gh workflow run cd-dev.yml --repo "$GH_REPO" --ref "$branch" || return 1

  # `gh workflow run` returns before the run is queryable.
  sleep 5
  local run_id
  run_id=$(gh run list --repo "$GH_REPO" --workflow=cd-dev.yml --branch "$branch" \
    --limit 1 --json databaseId --jq '.[0].databaseId' 2>/dev/null)

  if [[ -z "$run_id" ]]; then
    echo "Dispatched, but could not resolve the run id. Watch it with: gh run list --workflow=cd-dev.yml"
    return 0
  fi

  echo "Run: https://github.com/$GH_REPO/actions/runs/$run_id"
  gh run watch "$run_id" --repo "$GH_REPO" --exit-status
}

cmd_ssh() { ec2_ssh; }

cmd_logs() { ec2_ssh "cd /opt/digiin && ./deploy.sh logs"; }

cmd_schedule() {
  local st
  case "${1:-}" in
    on)  st=ENABLED ;;
    off) st=DISABLED ;;
    *) echo "Usage: digiin schedule on|off"; return 1 ;;
  esac
  local f; f=$(mktemp)
  aws scheduler get-schedule --name digiin-start --region "$EC2_REGION" > "$f"
  aws scheduler update-schedule --name digiin-start --region "$EC2_REGION" --state "$st" \
    --schedule-expression "$(jq -r .ScheduleExpression "$f")" \
    --schedule-expression-timezone "$(jq -r .ScheduleExpressionTimezone "$f")" \
    --flexible-time-window "$(jq -c .FlexibleTimeWindow "$f")" \
    --target "$(jq -c .Target "$f")" >/dev/null
  rm -f "$f"
  echo "digiin-start (auto-start 8-8 Mon-Fri) -> $st  (auto-stop untouched)"
}

cmd_ci() {
  local action
  case "${1:-}" in
    off) action=disable ;;
    on)  action=enable ;;
    *) echo "Usage: digiin ci off|on"; return 1 ;;
  esac
  local wf
  for wf in "${WORKFLOWS[@]}"; do
    if (cd "$MAIN_DIR" && gh workflow "$action" "$wf.yml" 2>/dev/null); then
      echo "  $action: $wf.yml"
    else
      echo "  skip: $wf.yml"
    fi
  done
  echo "cd-dev.yml left intact (manual deploy)."
}

cmd_help() {
  cat <<'EOF'
digiin — dev sessions + EC2 demo server ops

DEV SESSIONS (local)
  digiin init            start infra (Colima + postgres + redis)
  digiin open            open main project session
  digiin wt <branch>     create/open worktree session
  digiin ls              list worktrees and session status
  digiin rm <branch>     remove worktree and kill session

SERVER (EC2 demo — on-demand)
  digiin start           start the EC2 + wait until SSH is reachable
  digiin stop            stop the EC2 (compute off; auto-stop 8pm is the safety net)
  digiin status          EC2 state + public IP
  digiin deploy [branch] start if needed + run cd-dev.yml (gate -> build ->
                         migrate -> health -> auto-rollback). Default: demo
  digiin ssh             SSH into the server (digiin-dev)
  digiin logs            tail the running services' logs
  digiin schedule on|off toggle EventBridge auto-start (8-8 Mon-Fri)
  digiin ci off|on       toggle the GitHub Actions workflows (cd-dev stays on)

  digiin help            show this help
EOF
}

case "${1:-}" in
  init)       cmd_init ;;
  open)       cmd_open ;;
  wt)         cmd_wt "$2" ;;
  ls)         cmd_ls ;;
  rm)         cmd_rm "$2" ;;
  start|stop|status|deploy|ssh|logs)
              require_ec2; "cmd_$1" ;;
  schedule)   cmd_schedule "$2" ;;
  ci)         cmd_ci "$2" ;;
  help|-h|--help|"") cmd_help ;;
  *)
    echo "Unknown command: $1"
    echo ""
    cmd_help
    exit 1
    ;;
esac
