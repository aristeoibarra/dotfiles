#!/usr/bin/env bash
# Quick start: digiin development session
# Layout: [nvim | claude] side-by-side
# Always ensures the dev window exists

SESSION="digiin"
PROJECT_DIR="$HOME/digiin/project"
WINDOW_NAME="dev"

# Validate project directory
if [[ ! -d "$PROJECT_DIR" ]]; then
  echo "Error: $PROJECT_DIR does not exist"
  exit 1
fi

setup_dev_window() {
  local target="$1"
  tmux split-window -h -t "$target" -c "$PROJECT_DIR"
  tmux send-keys -t "${target}.1" "cd '$PROJECT_DIR' && nvim" Enter
  tmux send-keys -t "${target}.2" "cd '$PROJECT_DIR' && claude --dangerously-skip-permissions -c" Enter
  tmux resize-pane -t "${target}.2" -x "60%"
  tmux select-pane -t "${target}.1"
}

if tmux has-session -t "$SESSION" 2>/dev/null; then
  # Session exists — check if dev window exists
  if ! tmux list-windows -t "$SESSION" -F '#W' | grep -q "^${WINDOW_NAME}$"; then
    tmux new-window -t "$SESSION" -n "$WINDOW_NAME" -c "$HOME"
    setup_dev_window "$SESSION:$WINDOW_NAME"
  fi
  tmux select-window -t "$SESSION:$WINDOW_NAME"
  tmux attach-session -t "$SESSION"
else
  # Create session with dev window
  tmux new-session -d -s "$SESSION" -n "$WINDOW_NAME" -c "$HOME" -x "$(tput cols)" -y "$(tput lines)"
  setup_dev_window "$SESSION:$WINDOW_NAME"
  tmux attach-session -t "$SESSION"
fi
