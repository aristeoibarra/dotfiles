#!/usr/bin/env bash
# publicar-nota — vault → sitio, con gate.
#
#   publicar-nota            lista las notas de 10-notas con su estado
#   publicar-nota <nombre>   valida y publica la nota (filename, con o sin .md)
#
# Gate: frontmatter completo, estado listo/publicado, sin [[wikilinks]].
# Publica: copia a src/content/notas/, build, commit, push.
# Cierra: marca estado: publicado en el vault y respalda.
set -euo pipefail

VAULT_DIR="$HOME/vaults/aristeo"
NOTAS_DIR="$VAULT_DIR/10-notas"
SITE_DIR="$HOME/dev/aristeoibarra.com"
DEST_DIR="$SITE_DIR/src/content/notas"

die() { printf 'error: %s\n' "$1" >&2; exit 1; }

fm_field() { # fm_field <campo> <archivo> — valor de un campo del frontmatter
  awk -v k="$1" '
    NR==1 && $0=="---" { infm=1; next }
    infm && $0=="---" { exit }
    infm && index($0, k": ")==1 { sub(k": ", ""); print; exit }
  ' "$2"
}

# ── sin argumentos: listar ──────────────────────────────────────────
if [ $# -eq 0 ]; then
  [ -d "$NOTAS_DIR" ] || die "no existe $NOTAS_DIR"
  found=0
  for f in "$NOTAS_DIR"/*.md; do
    [ -e "$f" ] || break
    found=1
    printf '%-12s %s\n' "$(fm_field estado "$f" || echo '?')" "$(basename "$f" .md)"
  done
  [ "$found" -eq 1 ] || echo "(10-notas está vacía)"
  exit 0
fi

# ── localizar la nota ───────────────────────────────────────────────
name="${1%.md}"
src="$NOTAS_DIR/$name.md"
[ -f "$src" ] || die "no existe $src"

# ── gate ────────────────────────────────────────────────────────────
title="$(fm_field title "$src")"
date="$(fm_field date "$src")"
estado="$(fm_field estado "$src")"

[ -n "$title" ] || die "gate: falta 'title' en el frontmatter"
echo "$date" | grep -Eq '^[0-9]{4}-[0-9]{2}-[0-9]{2}$' || die "gate: 'date' debe ser YYYY-MM-DD (tiene: '$date')"
case "$estado" in
  listo|publicado) ;;
  borrador) die "gate: la nota sigue en 'estado: borrador' — cámbiala a 'listo' cuando sea el momento" ;;
  *) die "gate: 'estado' debe ser borrador|listo|publicado (tiene: '$estado')" ;;
esac
if grep -n '\[\[' "$src" >/dev/null; then
  grep -n '\[\[' "$src" | head -5 >&2
  die "gate: hay [[wikilinks]] de Obsidian — el sitio usa markdown estándar"
fi

# ── slug ────────────────────────────────────────────────────────────
slug="$(printf '%s' "$name" \
  | iconv -f UTF-8 -t ASCII//TRANSLIT \
  | tr '[:upper:]' '[:lower:]' \
  | tr -cs 'a-z0-9' '-' \
  | tr -s '-' | sed 's/^-//; s/-$//')"
[ -n "$slug" ] || die "no pude derivar un slug de '$name'"
dest="$DEST_DIR/$slug.md"

# ── copiar (sin el campo interno 'estado') ──────────────────────────
awk '
  NR==1 && $0=="---" { infm=1; print; next }
  infm && $0=="---" { infm=0; print; next }
  infm && index($0, "estado: ")==1 { next }
  { print }
' "$src" > "$dest"
echo "→ $slug.md copiada al sitio"

# ── build de verificación ───────────────────────────────────────────
( cd "$SITE_DIR" && npm run build >/dev/null 2>&1 ) || die "el build del sitio falló — nada se publicó; revisa la nota"
echo "→ build ok"

# ── commit + push del sitio ─────────────────────────────────────────
(
  cd "$SITE_DIR"
  git add "src/content/notas/$slug.md"
  if git diff --cached --quiet; then
    echo "→ sin cambios respecto a lo publicado"
  else
    git commit -q -m "feat: publish nota $slug"
    git push -q
    echo "→ pusheada: el deploy hará el resto"
  fi
)

# ── cerrar el ciclo en el vault ─────────────────────────────────────
if [ "$estado" = "listo" ]; then
  sd 'estado: listo' 'estado: publicado' "$src"
fi
(
  cd "$VAULT_DIR"
  git add "10-notas/$name.md"
  git diff --cached --quiet || { git commit -q -m "chore: publish $slug"; git push -q; }
)
echo "✓ publicada: $title"
