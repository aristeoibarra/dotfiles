#!/bin/bash
# Multi-theme switcher
# Supports any theme family (Kanagawa, Catppuccin, Tokyo Night, etc.)
#
# Usage: theme [name]       Switch to theme
#        theme               Interactive fzf picker
#        theme --current     Show current theme
#        theme --list        List available themes
#
# Adding a new theme:
#   1. Create themes/{name}.sh with color variables + metadata
#   2. For new Neovim families: add plugin in nvim/lua/plugins/colorschemes/
#   3. Run: theme {name}

set -e

DOTFILES="$HOME/dotfiles"
THEMES_DIR="$DOTFILES/themes"
STATE_DIR="$HOME/.local/state/theme"
STATE_FILE="$STATE_DIR/current"

# =============================================================================
# HELPERS
# =============================================================================

get_current() {
  [[ -f "$STATE_FILE" ]] && cat "$STATE_FILE" || echo "kanagawa-dragon"
}

list_themes() {
  for f in "$THEMES_DIR"/*.sh; do
    basename "$f" .sh
  done
}

# =============================================================================
# ARGUMENTS
# =============================================================================

case "${1:-}" in
  --current|-c) get_current; exit 0 ;;
  --list|-l) list_themes; exit 0 ;;
  --help|-h)
    echo "Usage: theme [name]"
    echo "  No args: interactive fzf picker"
    echo "  --current / -c: show current theme"
    echo "  --list / -l: list available themes"
    exit 0
    ;;
esac

THEME="${1:-}"

# Interactive fzf picker when no argument given
if [[ -z "$THEME" ]]; then
  if command -v fzf &>/dev/null; then
    CURRENT=$(get_current)
    THEME=$(list_themes | fzf \
      --prompt="Theme: " \
      --header="Current: $CURRENT" \
      --height=15 \
      --layout=reverse \
      --no-info) || exit 0
  else
    echo "Usage: theme [name]"
    echo "Current: $(get_current)"
    echo "Available: $(list_themes | tr '\n' ' ')"
    exit 1
  fi
fi

# Validate theme exists
if [[ ! -f "$THEMES_DIR/$THEME.sh" ]]; then
  echo "Unknown theme: $THEME"
  echo "Available: $(list_themes | tr '\n' ' ')"
  exit 1
fi

# Skip if already active
if [[ "$(get_current)" == "$THEME" ]]; then
  echo "Already using $THEME."
  exit 0
fi

# Source theme definitions
# shellcheck source=/dev/null
source "$THEMES_DIR/$THEME.sh"

# Defaults for optional fields
: "${TMUX_MODE:=manual}"
: "${OC_BG_ELEMENT:=$BLACK}"
: "${OC_BORDER:=$GRAY}"
: "${OC_BORDER_ACTIVE:=$BRIGHT_BLUE}"
: "${OC_BORDER_SUBTLE:=$BG}"
: "${OC_ACCENT:=$YELLOW}"
if [[ "$BG_MODE" == "dark" ]]; then
  : "${OC_DIFF_ADD_BG:=#1a2a1a}"
  : "${OC_DIFF_RM_BG:=#2a1a1a}"
else
  : "${OC_DIFF_ADD_BG:=#e0ecd0}"
  : "${OC_DIFF_RM_BG:=#f0d8d8}"
fi

echo "Switching to $THEME_DISPLAY..."

# =============================================================================
# STATE
# =============================================================================

apply_state() {
  mkdir -p "$STATE_DIR"
  echo "$THEME_NAME" > "$STATE_FILE"

  cat > "$STATE_DIR/colors.zsh" << EOF
# Auto-generated by 'theme' — do not edit manually
# Theme: $THEME_NAME

# FZF color scheme
FZF_THEME_COLORS="--color=fg:${FG},bg:${BG},hl:${BRIGHT_BLUE},fg+:${FG},bg+:${SELECTION},hl+:${BRIGHT_BLUE}"
FZF_THEME_COLORS+=" --color=info:${GREEN},prompt:${RED},pointer:${YELLOW},marker:${GREEN},spinner:${MAGENTA}"

# Zsh autosuggestion color
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=${AUTOSUGGEST}"
EOF
  echo "  State + colors.zsh saved"
}

# =============================================================================
# NEOVIM (live-reload only — colorscheme plugin reads state file)
# =============================================================================

apply_neovim() {
  while IFS= read -r -d '' sock; do
    nvim --server "$sock" --remote-send \
      "<Cmd>colorscheme $NVIM_COLORSCHEME<CR>" 2>/dev/null || true
  done < <(find /tmp -path '*/nvim.*/0' -type s -print0 2>/dev/null)
  echo "  Neovim live-reloaded"
}

# =============================================================================
# STARSHIP (regenerate palette between markers)
# =============================================================================

apply_starship() {
  local file="$DOTFILES/starship/starship.toml"
  [[ -f "$file" ]] || return

  local tmp
  tmp=$(mktemp)

  # Keep everything before the palette marker
  awk '/^# BEGIN THEME PALETTE/{exit} {print}' "$file" > "$tmp"

  # Write new palette
  cat >> "$tmp" << EOF
# BEGIN THEME PALETTE
[palettes.active_theme]
text = "$FG"
subtext = "$GRAY"
green = "$GREEN"
blue = "$BLUE"
cyan = "$CYAN"
red = "$RED"
yellow = "$YELLOW"
mauve = "$MAGENTA"
# END THEME PALETTE
EOF

  # Keep everything after END marker
  awk 'found{print} /^# END THEME PALETTE/{found=1}' "$file" >> "$tmp"

  mv "$tmp" "$file"
  echo "  Starship updated"
}

# =============================================================================
# TMUX (plugin mode for kanagawa, manual colors for others)
# =============================================================================

apply_tmux() {
  local theme_conf="$DOTFILES/tmux/theme.conf"

  case "$TMUX_MODE" in
    kanagawa)
      cat > "$theme_conf" << EOF
# $THEME_DISPLAY (auto-generated by 'theme')
# Kanagawa tmux plugin (local fork)
# Fork: removed window numbers from tabs
# Original: https://github.com/Nybkox/tmux-kanagawa
set -g @plugin "\$HOME/dotfiles/tmux/tmux-kanagawa"
set -g @kanagawa-theme '$TMUX_VARIANT'
set -g @kanagawa-plugins "cpu-usage ram-usage"
set -g @kanagawa-ignore-window-colors true
set -g @kanagawa-show-powerline true
set -g @kanagawa-show-left-icon session
EOF
      ;;
    *)
      cat > "$theme_conf" << EOF
# $THEME_DISPLAY (auto-generated by 'theme')
# Manual theme colors (no plugin)
set -g status-style "bg=${BG},fg=${FG}"
set -g status-left "#[bg=${BLUE},fg=${BG},bold] #S #[default] "
set -g status-right "#[fg=${GRAY}]%H:%M "
set -g status-left-length 30
set -g status-right-length 30
set -g window-status-current-format "#[bg=${SELECTION},fg=${BRIGHT_BLUE},bold] #W #[default]"
set -g window-status-format "#[fg=${GRAY}] #W #[default]"
set -g pane-border-style "fg=${GRAY}"
set -g pane-active-border-style "fg=${BRIGHT_BLUE}"
set -g message-style "bg=${SELECTION},fg=${FG}"
set -g mode-style "bg=${SELECTION},fg=${FG}"
EOF
      ;;
  esac
  echo "  Tmux config updated"

  if command -v tmux &>/dev/null && tmux list-sessions &>/dev/null; then
    tmux source-file ~/.tmux.conf 2>/dev/null && echo "  Tmux live-reloaded" || true
  fi
}

# =============================================================================
# ALACRITTY (generate theme.toml)
# =============================================================================

apply_alacritty() {
  local theme_file="$DOTFILES/alacritty/theme.toml"

  cat > "$theme_file" << EOF
# $THEME_DISPLAY (auto-generated by 'theme')

[colors.primary]
foreground = "$FG"
background = "$BG"

[colors.cursor]
text = "$BG"
cursor = "$WHITE"

[colors.selection]
text = "$WHITE"
background = "$SELECTION"

[colors.normal]
black = "$BLACK"
red = "$RED"
green = "$GREEN"
yellow = "$YELLOW"
blue = "$BLUE"
magenta = "$MAGENTA"
cyan = "$CYAN"
white = "$WHITE"

[colors.bright]
black = "$BRIGHT_BLACK"
red = "$BRIGHT_RED"
green = "$BRIGHT_GREEN"
yellow = "$BRIGHT_YELLOW"
blue = "$BRIGHT_BLUE"
magenta = "$BRIGHT_MAGENTA"
cyan = "$BRIGHT_CYAN"
white = "$BRIGHT_WHITE"
EOF
  echo "  Alacritty updated"
}

# =============================================================================
# GHOSTTY (replace colors between markers)
# =============================================================================

apply_ghostty() {
  local file="$DOTFILES/ghostty/config"
  [[ -f "$file" ]] || return

  local tmp
  tmp=$(mktemp)

  # Keep everything before theme markers (handle old and new marker names)
  awk '/^# BEGIN (KANAGAWA|THEME)/{exit} {print}' "$file" > "$tmp"

  cat >> "$tmp" << EOF
# BEGIN THEME
# $THEME_DISPLAY (auto-generated by 'theme')
background = ${BG//#/}
foreground = ${FG//#/}

cursor-style = block
cursor-color = ${WHITE//#/}
cursor-text = ${BG//#/}

selection-background = ${SELECTION//#/}
selection-foreground = ${WHITE//#/}

palette = 0=${BLACK//#/}
palette = 1=${RED//#/}
palette = 2=${GREEN//#/}
palette = 3=${YELLOW//#/}
palette = 4=${BLUE//#/}
palette = 5=${MAGENTA//#/}
palette = 6=${CYAN//#/}
palette = 7=${WHITE//#/}

palette = 8=${BRIGHT_BLACK//#/}
palette = 9=${BRIGHT_RED//#/}
palette = 10=${BRIGHT_GREEN//#/}
palette = 11=${BRIGHT_YELLOW//#/}
palette = 12=${BRIGHT_BLUE//#/}
palette = 13=${BRIGHT_MAGENTA//#/}
palette = 14=${BRIGHT_CYAN//#/}
palette = 15=${BRIGHT_WHITE//#/}
# END THEME
EOF

  # Preserve anything after END marker from original
  awk 'found{print} /^# END (KANAGAWA|THEME)/{found=1}' "$file" >> "$tmp"

  mv "$tmp" "$file"
  echo "  Ghostty updated"
}

# =============================================================================
# WARP (generate theme file)
# =============================================================================

apply_warp() {
  local theme_file="$DOTFILES/warp/themes/$THEME_NAME.yaml"
  cat > "$theme_file" << EOF
# $THEME_DISPLAY theme for Warp
accent: '$BLUE'
background: '$BG'
foreground: '$FG'
details: '$( [[ "$BG_MODE" == "light" ]] && echo "lighter" || echo "darker" )'

terminal_colors:
  normal:
    black: '$BLACK'
    red: '$RED'
    green: '$GREEN'
    yellow: '$YELLOW'
    blue: '$BLUE'
    magenta: '$MAGENTA'
    cyan: '$CYAN'
    white: '$WHITE'
  bright:
    black: '$BRIGHT_BLACK'
    red: '$BRIGHT_RED'
    green: '$BRIGHT_GREEN'
    yellow: '$BRIGHT_YELLOW'
    blue: '$BRIGHT_BLUE'
    magenta: '$BRIGHT_MAGENTA'
    cyan: '$BRIGHT_CYAN'
    white: '$BRIGHT_WHITE'
EOF
  echo "  Warp theme generated"
}

# =============================================================================
# OPENCODE (generate theme file)
# =============================================================================

apply_opencode() {
  local theme_file="$DOTFILES/opencode/themes/$THEME_NAME.json"
  cat > "$theme_file" << EOF
{
  "\$schema": "https://opencode.ai/theme.json",
  "theme": {
    "background": "$BG",
    "backgroundPanel": "$BG",
    "backgroundElement": "$OC_BG_ELEMENT",
    "text": "$FG",
    "textMuted": "$GRAY",
    "primary": "$BRIGHT_BLUE",
    "secondary": "$BLUE",
    "accent": "$OC_ACCENT",
    "error": "$BRIGHT_RED",
    "warning": "$YELLOW",
    "success": "$BRIGHT_GREEN",
    "info": "$BRIGHT_BLUE",
    "border": "$OC_BORDER",
    "borderActive": "$OC_BORDER_ACTIVE",
    "borderSubtle": "$OC_BORDER_SUBTLE",
    "diffAdded": "$BRIGHT_GREEN",
    "diffRemoved": "$BRIGHT_RED",
    "diffContext": "$GRAY",
    "diffHunkHeader": "$BRIGHT_MAGENTA",
    "diffHighlightAdded": "$GREEN",
    "diffHighlightRemoved": "$RED",
    "diffAddedBg": "$OC_DIFF_ADD_BG",
    "diffRemovedBg": "$OC_DIFF_RM_BG",
    "diffContextBg": "$BG",
    "diffLineNumber": "$GRAY",
    "diffAddedLineNumberBg": "$OC_DIFF_ADD_BG",
    "diffRemovedLineNumberBg": "$OC_DIFF_RM_BG",
    "markdownText": "$FG",
    "markdownHeading": "$OC_ACCENT",
    "markdownLink": "$BRIGHT_BLUE",
    "markdownLinkText": "$BLUE",
    "markdownCode": "$BRIGHT_GREEN",
    "markdownBlockQuote": "$MAGENTA",
    "markdownEmph": "$CYAN",
    "markdownStrong": "$OC_ACCENT",
    "markdownHorizontalRule": "$OC_BORDER",
    "markdownListItem": "$BRIGHT_BLUE",
    "markdownListEnumeration": "$BLUE",
    "markdownImage": "$BRIGHT_BLUE",
    "markdownImageText": "$BLUE",
    "markdownCodeBlock": "$FG",
    "syntaxComment": "$GRAY",
    "syntaxKeyword": "$MAGENTA",
    "syntaxFunction": "$BRIGHT_BLUE",
    "syntaxVariable": "$FG",
    "syntaxString": "$BRIGHT_GREEN",
    "syntaxNumber": "$OC_ACCENT",
    "syntaxType": "$BLUE",
    "syntaxOperator": "$YELLOW",
    "syntaxPunctuation": "$WHITE"
  }
}
EOF
  echo "  OpenCode theme generated"
}

# =============================================================================
# VSCODE
# =============================================================================

apply_vscode() {
  local file="$DOTFILES/vscode/settings.json"
  [[ -f "$file" ]] || return

  if [[ "$BG_MODE" == "dark" ]]; then
    sed -i '' -E "s/\"workbench.preferredDarkColorTheme\": \"[^\"]+\"/\"workbench.preferredDarkColorTheme\": \"$VSCODE_THEME\"/" "$file"
  else
    if grep -q 'preferredLightColorTheme' "$file"; then
      sed -i '' -E "s/\"workbench.preferredLightColorTheme\": \"[^\"]+\"/\"workbench.preferredLightColorTheme\": \"$VSCODE_THEME\"/" "$file"
    else
      sed -i '' -E "s/(\"workbench.preferredDarkColorTheme\": \"[^\"]+\")/\1,\n  \"workbench.preferredLightColorTheme\": \"$VSCODE_THEME\"/" "$file"
    fi
  fi
  echo "  VSCode updated"
}

# =============================================================================
# APPLY ALL
# =============================================================================

apply_state
apply_neovim
apply_starship
apply_tmux
apply_alacritty
apply_ghostty
apply_warp
apply_opencode
apply_vscode

echo ""
echo "$THEME_DISPLAY applied."
echo "Auto-reloaded: tmux, nvim"
echo "Restart needed: terminal, zsh (source ~/.zshrc)"
