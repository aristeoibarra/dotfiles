#!/bin/bash
# Multi-theme switcher
# Supports any theme family (Kanagawa, Catppuccin, Tokyo Night, etc.)
#
# Usage: theme [name]       Switch to theme
#        theme               Interactive fzf picker
#        theme --current     Show current theme
#        theme --list        List available themes
#
# Adding a new theme:
#   1. Create themes/{name}.sh with color variables + metadata
#   2. For new Neovim families: add plugin in nvim/lua/plugins/colorschemes/
#   3. Run: theme {name}

set -e

DOTFILES="$HOME/dotfiles"
THEMES_DIR="$DOTFILES/themes"
STATE_DIR="$HOME/.local/state/theme"
STATE_FILE="$STATE_DIR/current"

# =============================================================================
# HELPERS
# =============================================================================

get_current() {
  [[ -f "$STATE_FILE" ]] && cat "$STATE_FILE" || echo "kanagawa-dragon"
}

list_themes() {
  for f in "$THEMES_DIR"/*.sh; do
    basename "$f" .sh
  done
}

# =============================================================================
# ARGUMENTS
# =============================================================================

case "${1:-}" in
  --current|-c) get_current; exit 0 ;;
  --list|-l) list_themes; exit 0 ;;
  --help|-h)
    echo "Usage: theme [name]"
    echo "  No args: interactive fzf picker"
    echo "  --current / -c: show current theme"
    echo "  --list / -l: list available themes"
    exit 0
    ;;
esac

THEME="${1:-}"

# Interactive fzf picker when no argument given
if [[ -z "$THEME" ]]; then
  if command -v fzf &>/dev/null; then
    CURRENT=$(get_current)
    THEME=$(list_themes | fzf \
      --prompt="Theme: " \
      --header="Current: $CURRENT" \
      --height=15 \
      --layout=reverse \
      --no-info) || exit 0
  else
    echo "Usage: theme [name]"
    echo "Current: $(get_current)"
    echo "Available: $(list_themes | tr '\n' ' ')"
    exit 1
  fi
fi

# Validate theme exists
if [[ ! -f "$THEMES_DIR/$THEME.sh" ]]; then
  echo "Unknown theme: $THEME"
  echo "Available: $(list_themes | tr '\n' ' ')"
  exit 1
fi

# Skip if already active
if [[ "$(get_current)" == "$THEME" ]]; then
  echo "Already using $THEME."
  exit 0
fi

# Source theme definitions
# shellcheck source=/dev/null
source "$THEMES_DIR/$THEME.sh"

# Smart defaults for bat/delta themes based on family
get_bat_theme() {
  [[ -n "${BAT_THEME:-}" ]] && echo "$BAT_THEME" && return
  case "$THEME_FAMILY" in
    kanagawa)    echo "base16" ;;
    catppuccin)  echo "Catppuccin Mocha" ;;
    gruvbox)     echo "gruvbox-dark" ;;
    tokyonight)  echo "tokyonight_night" ;;
    rose-pine)   echo "base16" ;;
    *)           echo "base16" ;;
  esac
}

get_delta_theme() {
  [[ -n "${DELTA_THEME:-}" ]] && echo "$DELTA_THEME" && return
  case "$THEME_FAMILY" in
    catppuccin)  echo "Catppuccin Mocha" ;;
    *)           get_bat_theme ;;
  esac
}

echo "Switching to $THEME_DISPLAY..."

# =============================================================================
# STATE
# =============================================================================

apply_state() {
  mkdir -p "$STATE_DIR"
  echo "$THEME_NAME" > "$STATE_FILE"
  echo "$NVIM_COLORSCHEME" > "$STATE_DIR/nvim_colorscheme"

  local bat_theme
  bat_theme="$(get_bat_theme)"

  cat > "$STATE_DIR/colors.zsh" << EOF
# Auto-generated by 'theme' — do not edit manually
export THEME_NAME="$THEME_NAME"
export THEME_FAMILY="$THEME_FAMILY"
export BG_MODE="$BG_MODE"

# FZF color scheme
FZF_THEME_COLORS="--color=fg:${FG},bg:${BG},hl:${BRIGHT_BLUE},fg+:${FG},bg+:${SELECTION},hl+:${BRIGHT_BLUE}"
FZF_THEME_COLORS+=" --color=info:${GREEN},prompt:${RED},pointer:${YELLOW},marker:${GREEN},spinner:${MAGENTA}"

# Zsh autosuggestion color
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=${AUTOSUGGEST}"

# bat syntax theme
export BAT_THEME="$bat_theme"
EOF
  echo "  State + colors.zsh saved"
}

# =============================================================================
# NEOVIM (live-reload only — colorscheme plugin reads state file)
# =============================================================================

apply_neovim() {
  while IFS= read -r -d '' sock; do
    nvim --server "$sock" --remote-send \
      "<Cmd>colorscheme $NVIM_COLORSCHEME<CR>" 2>/dev/null || true
  done < <(find /tmp -path '*/nvim.*/0' -type s -print0 2>/dev/null)
  echo "  Neovim live-reloaded"
}

# =============================================================================
# STARSHIP (regenerate palette between markers)
# =============================================================================

apply_starship() {
  local file="$DOTFILES/starship/starship.toml"
  [[ -f "$file" ]] || return

  local tmp
  tmp=$(mktemp)

  # Keep everything before the palette marker
  awk '/^# BEGIN THEME PALETTE/{exit} {print}' "$file" > "$tmp"

  # Write new palette
  cat >> "$tmp" << EOF
# BEGIN THEME PALETTE
[palettes.active_theme]
text = "$FG"
subtext = "$GRAY"
green = "$GREEN"
blue = "$BLUE"
cyan = "$CYAN"
red = "$RED"
yellow = "$YELLOW"
mauve = "$MAGENTA"
# END THEME PALETTE
EOF

  # Keep everything after END marker
  awk 'found{print} /^# END THEME PALETTE/{found=1}' "$file" >> "$tmp"

  mv "$tmp" "$file"
  echo "  Starship updated"
}

# =============================================================================
# TMUX (universal status bar with powerline)
# =============================================================================

apply_tmux() {
  local theme_conf="$DOTFILES/tmux/theme.conf"
  local scripts_dir="$DOTFILES/tmux/scripts"

  cat > "$theme_conf" << EOF
# $THEME_DISPLAY (auto-generated by 'theme')

# Status bar
set -g status-style "bg=${BG},fg=${FG}"
set -g status-left-length 40
set -g status-right-length 80

# Left: session name with prefix indicator (powerline)
set -g status-left "#{?client_prefix,#[bg=${YELLOW}]#[fg=${BLACK}]#[bold] #S #[fg=${YELLOW}]#[bg=${BG}],#[bg=${BLUE}]#[fg=${BLACK}]#[bold] #S #[fg=${BLUE}]#[bg=${BG}]} "

# Right: CPU + RAM widgets with powerline separators
set -g status-right "#[fg=${SELECTION}]#[bg=${SELECTION}]#[fg=${FG}] CPU #($scripts_dir/cpu.sh) #[fg=${GRAY}]#[bg=${GRAY}]#[fg=${BLACK}] RAM #($scripts_dir/ram.sh) "

# Window tabs
set -g window-status-format "#[fg=${BG}]#[bg=${SELECTION}]#[fg=${GRAY}]#[bg=${SELECTION}] #W #[fg=${SELECTION}]#[bg=${BG}]"
set -g window-status-current-format "#[fg=${BG}]#[bg=${BRIGHT_BLUE}]#[fg=${BLACK}]#[bg=${BRIGHT_BLUE}]#[bold] #W #[fg=${BRIGHT_BLUE}]#[bg=${BG}]"
set -g window-status-separator " "

# Pane borders
set -g pane-border-style "fg=${GRAY}"
set -g pane-active-border-style "fg=${BRIGHT_BLUE}"

# Messages and mode
set -g message-style "bg=${SELECTION},fg=${FG}"
set -g mode-style "bg=${SELECTION},fg=${FG}"
EOF
  echo "  Tmux config updated"

  if command -v tmux &>/dev/null && tmux list-sessions &>/dev/null; then
    tmux source-file ~/.tmux.conf 2>/dev/null && echo "  Tmux live-reloaded" || true
  fi
}

# =============================================================================
# ALACRITTY (generate theme.toml)
# =============================================================================

apply_alacritty() {
  local theme_file="$DOTFILES/alacritty/theme.toml"

  cat > "$theme_file" << EOF
# $THEME_DISPLAY (auto-generated by 'theme')

[colors.primary]
foreground = "$FG"
background = "$BG"

[colors.cursor]
text = "$BG"
cursor = "$WHITE"

[colors.selection]
text = "$WHITE"
background = "$SELECTION"

[colors.normal]
black = "$BLACK"
red = "$RED"
green = "$GREEN"
yellow = "$YELLOW"
blue = "$BLUE"
magenta = "$MAGENTA"
cyan = "$CYAN"
white = "$WHITE"

[colors.bright]
black = "$BRIGHT_BLACK"
red = "$BRIGHT_RED"
green = "$BRIGHT_GREEN"
yellow = "$BRIGHT_YELLOW"
blue = "$BRIGHT_BLUE"
magenta = "$BRIGHT_MAGENTA"
cyan = "$BRIGHT_CYAN"
white = "$BRIGHT_WHITE"
EOF
  echo "  Alacritty updated"
}

# =============================================================================
# GHOSTTY (replace colors between markers)
# =============================================================================

apply_ghostty() {
  local file="$DOTFILES/ghostty/config"
  [[ -f "$file" ]] || return

  local tmp
  tmp=$(mktemp)

  # Keep everything before theme markers (handle old and new marker names)
  awk '/^# BEGIN (KANAGAWA|THEME)/{exit} {print}' "$file" > "$tmp"

  cat >> "$tmp" << EOF
# BEGIN THEME
# $THEME_DISPLAY (auto-generated by 'theme')
background = ${BG//#/}
foreground = ${FG//#/}

cursor-style = block
cursor-color = ${WHITE//#/}
cursor-text = ${BG//#/}

selection-background = ${SELECTION//#/}
selection-foreground = ${WHITE//#/}

palette = 0=${BLACK//#/}
palette = 1=${RED//#/}
palette = 2=${GREEN//#/}
palette = 3=${YELLOW//#/}
palette = 4=${BLUE//#/}
palette = 5=${MAGENTA//#/}
palette = 6=${CYAN//#/}
palette = 7=${WHITE//#/}

palette = 8=${BRIGHT_BLACK//#/}
palette = 9=${BRIGHT_RED//#/}
palette = 10=${BRIGHT_GREEN//#/}
palette = 11=${BRIGHT_YELLOW//#/}
palette = 12=${BRIGHT_BLUE//#/}
palette = 13=${BRIGHT_MAGENTA//#/}
palette = 14=${BRIGHT_CYAN//#/}
palette = 15=${BRIGHT_WHITE//#/}
# END THEME
EOF

  # Preserve anything after END marker from original
  awk 'found{print} /^# END (KANAGAWA|THEME)/{found=1}' "$file" >> "$tmp"

  mv "$tmp" "$file"
  echo "  Ghostty updated"
}

# =============================================================================
# WARP (generate theme file)
# =============================================================================

apply_warp() {
  local theme_file="$DOTFILES/warp/themes/$THEME_NAME.yaml"
  local warp_themes_dir="$HOME/.warp/themes"

  cat > "$theme_file" << EOF
# $THEME_DISPLAY theme for Warp
accent: '$BLUE'
background: '$BG'
foreground: '$FG'
details: '$( [[ "$BG_MODE" == "light" ]] && echo "lighter" || echo "darker" )'

terminal_colors:
  normal:
    black: '$BLACK'
    red: '$RED'
    green: '$GREEN'
    yellow: '$YELLOW'
    blue: '$BLUE'
    magenta: '$MAGENTA'
    cyan: '$CYAN'
    white: '$WHITE'
  bright:
    black: '$BRIGHT_BLACK'
    red: '$BRIGHT_RED'
    green: '$BRIGHT_GREEN'
    yellow: '$BRIGHT_YELLOW'
    blue: '$BRIGHT_BLUE'
    magenta: '$BRIGHT_MAGENTA'
    cyan: '$BRIGHT_CYAN'
    white: '$BRIGHT_WHITE'
EOF

  # Ensure symlink exists in Warp themes directory
  if [[ -d "$warp_themes_dir" ]]; then
    ln -sf "$theme_file" "$warp_themes_dir/$THEME_NAME.yaml"
  fi
  echo "  Warp theme generated"
}

# =============================================================================
# OPENCODE (generate custom theme JSON + update tui.json)
# =============================================================================

apply_opencode() {
  local themes_dir="$DOTFILES/opencode/themes"
  local theme_file="$themes_dir/$THEME_NAME.json"
  local tui_file="$HOME/.config/opencode/tui.json"

  mkdir -p "$themes_dir"

  # Update active theme reference in tui.json
  if [[ -f "$tui_file" ]]; then
    local tmp
    tmp=$(mktemp)
    sed "s/\"theme\": \"[^\"]*\"/\"theme\": \"$THEME_NAME\"/" "$tui_file" > "$tmp"
    mv "$tmp" "$tui_file"
  fi

  cat > "$theme_file" << EOF
{
  "\$schema": "https://opencode.ai/theme.json",
  "theme": {
    "primary": "$BRIGHT_BLUE",
    "secondary": "$BLUE",
    "accent": "$YELLOW",
    "error": "$BRIGHT_RED",
    "warning": "$YELLOW",
    "success": "$BRIGHT_GREEN",
    "info": "$BRIGHT_BLUE",
    "text": "$FG",
    "textMuted": "$GRAY",
    "background": "$BG",
    "backgroundPanel": "$BG",
    "backgroundElement": "$BLACK",
    "border": "$GRAY",
    "borderActive": "$BRIGHT_BLUE",
    "borderSubtle": "$BRIGHT_BLACK",
    "diffAdded": "$BRIGHT_GREEN",
    "diffRemoved": "$BRIGHT_RED",
    "diffContext": "$GRAY",
    "diffHunkHeader": "$BRIGHT_MAGENTA",
    "diffHighlightAdded": "$GREEN",
    "diffHighlightRemoved": "$RED",
    "diffAddedBg": {"dark": "#1a2a1a", "light": "#e0ecd0"},
    "diffRemovedBg": {"dark": "#2a1a1a", "light": "#f0d8d8"},
    "diffContextBg": "$BG",
    "diffLineNumber": "$GRAY",
    "diffAddedLineNumberBg": {"dark": "#1a2a1a", "light": "#e0ecd0"},
    "diffRemovedLineNumberBg": {"dark": "#2a1a1a", "light": "#f0d8d8"},
    "markdownText": "$FG",
    "markdownHeading": "$YELLOW",
    "markdownLink": "$BRIGHT_BLUE",
    "markdownLinkText": "$BLUE",
    "markdownCode": "$BRIGHT_GREEN",
    "markdownBlockQuote": "$MAGENTA",
    "markdownEmph": "$CYAN",
    "markdownStrong": "$YELLOW",
    "markdownHorizontalRule": "$GRAY",
    "markdownListItem": "$BRIGHT_BLUE",
    "markdownListEnumeration": "$BLUE",
    "markdownImage": "$BRIGHT_BLUE",
    "markdownImageText": "$BLUE",
    "markdownCodeBlock": "$FG",
    "syntaxComment": "$GRAY",
    "syntaxKeyword": "$MAGENTA",
    "syntaxFunction": "$BRIGHT_BLUE",
    "syntaxVariable": "$FG",
    "syntaxString": "$BRIGHT_GREEN",
    "syntaxNumber": "$YELLOW",
    "syntaxType": "$BLUE",
    "syntaxOperator": "$YELLOW",
    "syntaxPunctuation": "$WHITE"
  }
}
EOF
  echo "  OpenCode theme generated"
}

# =============================================================================
# DELTA (git pager syntax theme)
# =============================================================================

apply_delta() {
  local delta_dir="$HOME/.config/delta"
  local delta_conf="$delta_dir/theme.gitconfig"
  mkdir -p "$delta_dir"

  local dark_flag
  [[ "$BG_MODE" == "dark" ]] && dark_flag="true" || dark_flag="false"

  cat > "$delta_conf" << EOF
# Auto-generated by 'theme' — do not edit manually
[delta]
    syntax-theme = $(get_delta_theme)
    dark = $dark_flag
EOF
  echo "  Delta config updated"
}

# =============================================================================
# LAZYGIT (theme colors)
# =============================================================================

apply_lazygit() {
  local lazygit_dir="$HOME/Library/Application Support/lazygit"
  local lazygit_conf="$lazygit_dir/config.yml"
  mkdir -p "$lazygit_dir"

  local theme_block
  theme_block=$(cat << EOF
# BEGIN THEME
gui:
  theme:
    activeBorderColor:
      - "${BRIGHT_BLUE}"
      - bold
    inactiveBorderColor:
      - "${GRAY}"
    selectedLineBgColor:
      - "${SELECTION}"
    unstagedChangesColor:
      - "${RED}"
    defaultFgColor:
      - "${FG}"
    searchingActiveBorderColor:
      - "${YELLOW}"
# END THEME
EOF
)

  if [[ ! -f "$lazygit_conf" ]]; then
    echo "$theme_block" > "$lazygit_conf"
  elif grep -q '# BEGIN THEME' "$lazygit_conf"; then
    local tmp
    tmp=$(mktemp)
    awk '/^# BEGIN THEME/{skip=1; next} /^# END THEME/{skip=0; next} !skip{print}' "$lazygit_conf" > "$tmp"
    echo "$theme_block" >> "$tmp"
    mv "$tmp" "$lazygit_conf"
  else
    echo "" >> "$lazygit_conf"
    echo "$theme_block" >> "$lazygit_conf"
  fi
  echo "  Lazygit config updated"
}

# =============================================================================
# VSCODE
# =============================================================================

apply_vscode() {
  local file="$DOTFILES/vscode/settings.json"
  [[ -f "$file" ]] || return
  [[ -n "${VSCODE_THEME:-}" ]] || return

  if [[ "$BG_MODE" == "dark" ]]; then
    sed -i '' -E "s/\"workbench.preferredDarkColorTheme\": \"[^\"]+\"/\"workbench.preferredDarkColorTheme\": \"$VSCODE_THEME\"/" "$file"
  else
    if grep -q 'preferredLightColorTheme' "$file"; then
      sed -i '' -E "s/\"workbench.preferredLightColorTheme\": \"[^\"]+\"/\"workbench.preferredLightColorTheme\": \"$VSCODE_THEME\"/" "$file"
    else
      sed -i '' -E "s/(\"workbench.preferredDarkColorTheme\": \"[^\"]+\")/\1,\n  \"workbench.preferredLightColorTheme\": \"$VSCODE_THEME\"/" "$file"
    fi
  fi
  echo "  VSCode updated"
}

# =============================================================================
# APPLY ALL
# =============================================================================

apply_state
apply_neovim
apply_starship
apply_tmux
apply_alacritty
apply_ghostty
apply_warp
apply_opencode
apply_delta
apply_lazygit
apply_vscode

echo ""
echo "$THEME_DISPLAY applied."
echo "Auto-reloaded: tmux, nvim"
echo "Restart needed: terminal, zsh (source ~/.zshrc)"
