{
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push)",
      "Bash(git pull*)",
      "Bash(git fetch*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git stash*)",
      "Bash(gh *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(yarn *)",
      "Bash(bun *)",
      "Bash(eza *)",
      "Bash(fd *)",
      "Bash(bat *)",
      "Bash(rg *)",
      "Bash(tree *)",
      "Bash(which *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(chmod *)",
      "Bash(docker *)",
      "Bash(make *)",
      "Bash(curl *)",
      "Bash(jq *)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "mcp__ide__getDiagnostics",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(psql:*)",
      "mcp__chrome-devtools__evaluate_script",
      "mcp__chrome-devtools__hover",
      "mcp__chrome-devtools__take_screenshot"
    ],
    "deny": [],
    "ask": [
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(git rebase*)",
      "Bash(rm -rf *)"
    ],
    "defaultMode": "auto"
  },
  "skillOverrides": {
    "calibre": "off",
    "mu": "off",
    "podcast": "off",
    "bird": "off",
    "rdt": "off",
    "ndb": "off",
    "digest": "off",
    "bw": "off"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify-tmux.sh",
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify-tmux.sh",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "railway-skills": {
      "source": {
        "source": "github",
        "repo": "railwayapp/railway-skills"
      }
    }
  },
  "language": "es",
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "editorMode": "vim",
  "switchModelsOnFlag": false,
  "remoteControlAtStartup": false,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "model": "opus[1m]"
}
