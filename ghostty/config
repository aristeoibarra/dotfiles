
# Ghostty Configuration
# Theme synced via `theme` command

# Font
font-family = "JetBrainsMono Nerd Font Mono"
font-size = 18
font-thicken = true
adjust-cell-height = 2

# Window
window-padding-x = 15
window-padding-y = 12
window-decoration = false
background-opacity = 1

# Terminal
term = xterm-256color

# Mouse
mouse-hide-while-typing = true

# Cursor
cursor-style = block
cursor-style-blink = false

# Clipboard
clipboard-read = allow
clipboard-write = allow

# macOS specific
macos-option-as-alt = true

# Keybindings
keybind = shift+enter=text:\x1b\r

# BEGIN THEME
# Gruvbox Dark (auto-generated by 'theme')
background = 282828
foreground = ebdbb2

cursor-color = ebdbb2
cursor-text = 282828

selection-background = 504945
